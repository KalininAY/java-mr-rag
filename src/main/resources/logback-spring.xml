<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- Console appender (default Spring Boot pattern) -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p ${PID:- } --- [%15.15t] %-40.40logger{39} : %m%n</pattern>
    </encoder>
  </appender>

  <!--
    InMemoryLogAppender is instantiated by Logback directly (not as a Spring bean).
    It is accessed from Spring via the static InMemoryLogAppender.getInstance() accessor.
  -->
  <appender name="MEMORY" class="com.example.mrrag.app.logging.InMemoryLogAppender">
    <!-- no configuration needed -->
  </appender>

  <root level="DEBUG">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="MEMORY"/>
  </root>

  <!-- Reduce noise from verbose libraries -->
  <logger name="org.eclipse.jgit"        level="WARN"/>
  <logger name="org.springframework"     level="INFO"/>
  <logger name="com.github.javaparser"   level="WARN"/>
  <logger name="org.gitlab4j"            level="INFO"/>

</configuration>
