# Copy this file to .env and fill in your values
# Spring Boot loads .env automatically when using the Gradle bootRun task
# (add id 'co.uzzu.dotenv.gradle' plugin), or export manually:
#   export $(cat .env | xargs) && ./gradlew bootRun

# GitLab instance URL
GITLAB_URL=https://gitlab.example.com

# Personal access token (scope: read_api + read_repository)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Directory where branches are cloned (must be writable)
WORKSPACE_DIR=/tmp/mr-rag-workspace
